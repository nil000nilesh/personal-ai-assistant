# ══════════════════════════════════════════════════════
#  CaseDesk AI — Environment Variables
#  Is file ko copy karke .env banao (gitignored hai)
# ══════════════════════════════════════════════════════

# ── Telegram Bot ──────────────────────────────────────
# Step 1: Telegram mein @BotFather ko message karo
# Step 2: /newbot command do, naam aur username choose karo
# Step 3: Jo token milega woh yahan paste karo
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Firebase Service Account ──────────────────────────
# Step 1: Firebase Console → Project Settings → Service Accounts
# Step 2: "Generate New Private Key" click karo
# Step 3: Downloaded JSON file ka content yahan paste karo (ek line mein)
# Ya firebase-service-account.json file project root mein rakh sakte ho (gitignored)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Webhook Mode (optional — Render/Railway ke liye) ──
# Local development mein yeh set karne ki zaroorat nahi (polling mode use hoga)
# Production mein apni deployed app ka URL daalo
# WEBHOOK_URL=https://your-app.onrender.com
