rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == "nil000nilesh@gmail.com";
    }
    function isOwner() {
      return request.auth != null &&
             request.auth.token.email == resource.data.userId;
    }
    function savingAsOwner() {
      return request.auth != null &&
             request.resource.data.userId == request.auth.token.email;
    }

    match /notebooks/{docId} {
      allow read:           if isAdmin() || isOwner();
      allow create:         if isAdmin() || savingAsOwner();
      allow update, delete: if isAdmin() || isOwner();
    }
    match /notes/{docId} {
      allow read:           if isAdmin() || isOwner();
      allow create:         if isAdmin() || savingAsOwner();
      allow update, delete: if isAdmin() || isOwner();
    }
    match /tasks/{docId} {
      allow read:           if isAdmin() || isOwner();
      allow create:         if isAdmin() || savingAsOwner();
      allow update, delete: if isAdmin() || isOwner();
    }
    match /reminders/{docId} {
      allow read:           if isAdmin() || isOwner();
      allow create:         if isAdmin() || savingAsOwner();
      allow update, delete: if isAdmin() || isOwner();
    }
    match /chats/{docId} {
      allow read:           if isAdmin() || isOwner();
      allow create:         if isAdmin() || savingAsOwner();
      allow update, delete: if isAdmin() || isOwner();
    }

    // Encrypted passwords + vault PIN hash config — same pattern as other collections
    match /vault_entries/{docId} {
      allow read:           if isAdmin() || isOwner();
      allow create:         if isAdmin() || savingAsOwner();
      allow update, delete: if isAdmin() || isOwner();
    }

    match /allowed_users/{docId} {
      allow read:  if isAdmin() ||
                      (request.auth != null &&
                       resource.data.email == request.auth.token.email);
      allow write: if isAdmin();
    }

    match /system_settings/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
